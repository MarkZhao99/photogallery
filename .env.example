# local, icloud or webdav
PHOTO_STORAGE=icloud

# Flask app settings
APP_HOST=127.0.0.1
PORT=5001
FLASK_DEBUG=false
MAX_UPLOAD_MB=50
ADMIN_USERNAME=zxxk
ADMIN_PASSWORD=change-this-admin-password
ADMIN_SESSION_SECRET=change-this-session-secret
PUBLIC_SITE_ONLY=false

# When PHOTO_STORAGE=icloud, photos and metadata are stored inside your local
# iCloud Drive folder and sync through iCloud automatically.
ICLOUD_PHOTO_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/web图库

# Optional: when configured, the app will analyze the latest photos in a country
# and auto-generate a Chinese curatorial paragraph for that country's section.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60
COUNTRY_DESCRIPTION_IMAGE_LIMIT=6
COUNTRY_DESCRIPTION_MAX_EDGE=1440
COUNTRY_DESCRIPTION_MAX_BYTES=900000

# Enable these when you want to store files on your own WebDAV endpoint
# backed by OpenList/AList + AliyunDrive Open.
WEBDAV_BASE_URL=https://your-webdav-host/dav/
WEBDAV_USERNAME=your-username
WEBDAV_PASSWORD=your-password
WEBDAV_REMOTE_DIR=photo-wall
WEBDAV_METADATA_REMOTE_NAME=.photo-metadata.json
